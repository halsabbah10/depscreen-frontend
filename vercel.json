{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://halsabbah-depscreen.hf.space/api/:path*"
    },
    {
      "source": "/health/:path*",
      "destination": "https://halsabbah-depscreen.hf.space/health/:path*"
    },
    {
      "source": "/((?!api|health).*)",
      "destination": "/index.html"
    }
  ]
}
